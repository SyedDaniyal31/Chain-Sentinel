# --- Environment & secrets (NEVER commit) ---
.env
.env.*
!.env.example
!.env.*.example
*.pem
*.key
*.p12
secrets/
credentials.json
service-account*.json

# --- OS ---
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# --- Editors & IDEs ---
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
*.swp
*.swo
*~
.project
.classpath
.settings/

