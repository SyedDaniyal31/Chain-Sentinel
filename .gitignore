node_modules/
.npm
.pnpm-store/
.yarn/
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.next/
out/
build/
dist/
.turbo/
.vercel
*.tsbuildinfo
next-env.d.ts
coverage/
.nyc_output/
.eslintcache
.stylelintcache
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Python / Backend ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
ENV/
env/
.eggs/
