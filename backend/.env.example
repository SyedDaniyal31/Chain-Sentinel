# Backend environment — copy to .env
# cp .env.example .env  (or run init-project.ps1)

APP_NAME=ChainSentinel API
APP_ENV=development
APP_DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=dev-secret-change-in-production

DATABASE_URL=postgresql+asyncpg://chainsentinel:chainsentinel_dev@localhost:5432/chainsentinel
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_AUTO_CREATE_TABLES=true
REDIS_URL=redis://localhost:6379/0

CORS_ORIGINS=http://localhost:3000

# Primary chain RPC override — applies to CHAIN_ID below; other chains use ChainRegistry defaults (M5.0)
# Ethereum Mainnet: CHAIN_ID=1  ETH_RPC_URL=https://ethereum-rpc.publicnode.com
# Ethereum Sepolia:  CHAIN_ID=11155111  ETH_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
ETH_RPC_URL=http://127.0.0.1:8545
ETH_RPC_TIMEOUT_SECONDS=30
CHAIN_ID=31337

# Optional: block explorer API key (Etherscan-compatible — used across all supported chains)
# ETHERSCAN_API_KEY=

# Optional: Rug Pull Detector V3 trade simulation (requires Foundry Anvil)
TRADE_SIMULATION_ENABLED=false
ANVIL_RPC_URL=http://127.0.0.1:8545
FORK_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
SIMULATION_ETH_AMOUNT_WEI=100000000000000000
ANVIL_AUTO_START=false
ANVIL_BINARY=anvil
