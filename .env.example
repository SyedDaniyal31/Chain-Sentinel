# ChainSentinel — Root environment template
# Copy to .env and fill in values. NEVER commit .env

# Application
APP_NAME=ChainSentinel
APP_ENV=development
APP_DEBUG=true

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Backend (FastAPI)
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
CORS_ORIGINS=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://chainsentinel:chainsentinel_dev@localhost:5432/chainsentinel
POSTGRES_USER=chainsentinel
POSTGRES_PASSWORD=chainsentinel_dev
POSTGRES_DB=chainsentinel
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis (optional — Phase 2)
REDIS_URL=redis://localhost:6379/0

# Blockchain
ETH_RPC_URL=http://127.0.0.1:8545
CHAIN_ID=31337
DEPLOYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# AI (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:4b
